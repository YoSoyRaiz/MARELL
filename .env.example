# ============================================================
# MARELL — Environment variables template
# Copy to .env.local for development. In production set these in
# Vercel's project settings.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://marell.app

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@marell.app

# ── Anthropic (Claude) ──────────────────────────────────────
# Used by /api/receipts/parse to extract amount, date and payee
# from receipt photos. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# ── Cron ────────────────────────────────────────────────────
# Required to authorize hits to /api/cron/* routes.
CRON_SECRET=

# ── Billing: feature flag ──────────────────────────────────
# Flip to "1" or "true" once at least one provider is fully
# configured to actually charge users. While "0" the upgrade
# flow is reachable but Pro features stay unlocked for everyone
# (so we can ship the UI dark before the gateway is ready).
BILLING_ENFORCEMENT_ENABLED=0

# ── Billing: Azul ───────────────────────────────────────────
# Get these from your Azul merchant onboarding packet.
AZUL_MERCHANT_ID=
AZUL_AUTH1=
AZUL_AUTH2=
AZUL_API_KEY=
AZUL_PAYMENT_PAGE_URL=https://pagos.azul.com.do/PaymentPage/
# Azul signs server-to-server callbacks; grab the secret from
# their dashboard.
AZUL_WEBHOOK_HMAC_SECRET=
# Production Azul requires SSL client certs — store the cert
# either as a base64 blob or upload to Vercel Blob and load at
# runtime.
AZUL_SSL_CERT_PATH=

# ── Billing: PayPal ─────────────────────────────────────────
# Sandbox first, then swap to live credentials.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Create the recurring plan once in PayPal's dashboard
# (Products → Plans). Paste the plan id here.
PAYPAL_PLAN_ID=
# From the webhooks settings in PayPal dashboard.
PAYPAL_WEBHOOK_ID=
# Defaults to live in production, sandbox elsewhere. Override if needed.
PAYPAL_BASE_URL=
